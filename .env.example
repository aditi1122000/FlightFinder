# Copy to .env and fill in your keys

# Required for conversational LLM
MISTRAL_API_KEY=your_mistral_api_key

# Flight search (RapidAPI e.g. booking-com15)
RAPIDAPI_KEY=your_rapidapi_key
RAPIDAPI_HOST=booking-com15.p.rapidapi.com

# Optional: aviation / airport data
AIRPORT_API_KEY=
AIRPORT_API_BASE_URL=https://api.aviationstack.com/v1

# Optional: Amadeus (scripts/amadeus_token.py)
# AMADEUS_API_KEY=
# AMADEUS_API_SECRET=
# AMADEUS_ACCESS_TOKEN=
# AMADEUS_BASE_URL=https://test.api.amadeus.com

# Optional: Supabase (conversation persistence)
# Get from Supabase Dashboard: Project Settings > API (or API Keys tab for new keys)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Elevated (recommended for server): SUPABASE_SECRET_KEY (sb_secret_...) or SUPABASE_SERVICE_ROLE_KEY
# Low-privilege (respects RLS): SUPABASE_PUBLISHABLE_KEY (sb_publishable_...); legacy SUPABASE_ANON_KEY
